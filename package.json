{
  "name": "simcitypedscards",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx server/dev.ts",
    "start": "tsx server/start.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "vitest run",
